# Safe local defaults. Never commit real credentials.
SFD_SOURCE=local
SFD_DATA_PATH=data/aps.csv
SFD_SCHEMA_PATH=configs/schema.yaml
SFD_OUTPUT_DIR=outputs/latest
SFD_ARTIFACT_ROOT=artifacts
SFD_MODEL_ROOT=models
SFD_SEED=42
SFD_TEST_SIZE=0.2
SFD_DRIFT_THRESHOLD=0.05
SFD_MAX_UPLOAD_BYTES=10485760
SFD_CORS_ORIGINS=http://localhost:3000
SFD_API_HOST=127.0.0.1
SFD_API_PORT=8080

# MongoDB source: replace only in a private environment or secret manager.
MONGO_DB_URL=mongodb://localhost:27017/sensor_fault_detection
MONGO_DATABASE=sensor_data
MONGO_COLLECTION=sensor_collection

# Optional Cloudflare R2 source/artifact sync. Leave disabled for local development.
SFD_R2_BUCKET=
SFD_R2_DATA_KEY=
SFD_R2_ARTIFACT_PREFIX=sensor-fault-detection
SFD_R2_SYNC_ENABLED=false
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
